EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy JWT anon key (eyJ...) or new publishable key (sb_publishable_...) from Supabase → API
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Website origin only (no /dashboard). Support opens {origin}/support
EXPO_PUBLIC_WEB_APP_URL=https://your-web-app.vercel.app
